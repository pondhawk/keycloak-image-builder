# keycloak.env — ENVIRONMENT-SPECIFIC, non-secret runtime config (ADR-0002).
# Rendered at boot from user-data. NOT baked into the AMI. NO secrets here
# (DB username/password come from /run/keycloak/secrets.env — ADR-0008).
# Placeholders are filled by the boot config step (envsubst).

# Database endpoint (non-secret; composed from host/port/dbname + vendor — ADR-0003/0008)
KC_DB_URL=${KC_DB_URL}

# Public hostname = the ALB URL (issuer/redirects use this — ADR-0009)
KC_HOSTNAME=${KC_HOSTNAME}

# JGroups bind address = this instance's private IP (ADR-0009)
KC_CACHE_EMBEDDED_NETWORK_BIND_ADDRESS=${NODE_PRIVATE_IP}

# JVM sizing
JAVA_OPTS_APPEND=${JAVA_OPTS_APPEND}
