#!/usr/bin/env bash
#
# kcimage — Keycloak Image Builder CLI (dispatcher only; no business logic).
# See docs/adr/ for architecture. Coding standards: .claude/coding-standards.md
#
set -Eeuo pipefail
IFS=$'\n\t'

# --- Resolve install layout (works from the repo or from an installed copy) ---
KCIMAGE_SELF="$(readlink -f "${BASH_SOURCE[0]}")"
KCIMAGE_BIN_DIR="$(dirname "$KCIMAGE_SELF")"
if [[ -d "$KCIMAGE_BIN_DIR/../lib" && -d "$KCIMAGE_BIN_DIR/subcommands" ]]; then
  # running from the repo: scripts/kcimage + ../lib + ./subcommands
  KCIMAGE_LIB_DIR="$(readlink -f "$KCIMAGE_BIN_DIR/../lib")"
  KCIMAGE_CMD_DIR="$(readlink -f "$KCIMAGE_BIN_DIR/subcommands")"
else
  # running installed: /usr/local/bin/kcimage + /usr/local/lib/kcimage/{lib,subcommands}
  KCIMAGE_LIB_DIR="${KCIMAGE_LIB_DIR:-/usr/local/lib/kcimage/lib}"
  KCIMAGE_CMD_DIR="${KCIMAGE_CMD_DIR:-/usr/local/lib/kcimage/subcommands}"
fi
readonly KCIMAGE_SELF KCIMAGE_BIN_DIR KCIMAGE_LIB_DIR KCIMAGE_CMD_DIR

# shellcheck source=../lib/common.sh
source "$KCIMAGE_LIB_DIR/common.sh"
# shellcheck source=../lib/log.sh
source "$KCIMAGE_LIB_DIR/log.sh"
# shellcheck source=../lib/validate.sh
source "$KCIMAGE_LIB_DIR/validate.sh"
# shellcheck source=../lib/selinux.sh
source "$KCIMAGE_LIB_DIR/selinux.sh"

# --- Known subcommands (blueprint §11) ---
# KIB is a model-instance build tool: install/update → verify → prepare-for-image.
readonly KCIMAGE_COMMANDS=(install upgrade verify seal clean version)

usage() {
  local cmds
  cmds="$(
    IFS=' '
    echo "${KCIMAGE_COMMANDS[*]}"
  )"
  cat << EOF
kcimage — Keycloak Image Builder

Usage: kcimage [global-options] <command> [args]

Global options:
  --dry-run     Perform no mutating action
  --verbose     Debug-level logging
  -h, --help    Show this help
  --version     Show version

Commands:
  ${cmds}
EOF
}

main() {
  # Global flags (before the command)
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run)
        DRY_RUN=1
        shift
        ;;
      --verbose)
        VERBOSE=1
        shift
        ;;
      -h | --help)
        usage
        return 0
        ;;
      --version)
        cmd_dispatch version
        return $?
        ;;
      --)
        shift
        break
        ;;
      -*)
        log_error "unknown global option: $1"
        usage
        return "$EX_USAGE"
        ;;
      *) break ;;
    esac
  done

  [[ $# -ge 1 ]] || {
    usage
    return "$EX_USAGE"
  }
  local cmd="$1"
  shift
  cmd_dispatch "$cmd" "$@"
}

cmd_dispatch() {
  local cmd="$1"
  shift || true
  local file fn
  file="$KCIMAGE_CMD_DIR/${cmd}.sh"
  fn="cmd_${cmd//-/_}"
  if [[ -f "$file" ]]; then
    # shellcheck source=/dev/null
    source "$file"
    if declare -F "$fn" > /dev/null; then
      # `version` prints the version itself; every other command gets the banner.
      [[ "$cmd" == "version" ]] || kib_banner
      "$fn" "$@"
      return $?
    fi
  fi
  log_error "command not implemented: ${cmd} (planned; see ROADMAP.md)"
  return "$EX_UNIMPLEMENTED"
}

main "$@"
